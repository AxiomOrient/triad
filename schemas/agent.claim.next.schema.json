{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triad.local/schemas/agent.claim.next.schema.json",
  "title": "Triad Agent Claim Next Response",
  "type": "object",
  "allOf": [
    {
      "$ref": "./envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "command": {
          "const": "claim.next",
          "type": "string"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "claim_id",
            "status",
            "reason",
            "next_action"
          ],
          "properties": {
            "claim_id": {
              "type": "string",
              "pattern": "^REQ-[a-z0-9-]+\\-\\d{3}$"
            },
            "status": {
              "type": "string",
              "enum": [
                "healthy",
                "needs-code",
                "needs-test",
                "needs-spec",
                "contradicted",
                "blocked"
              ]
            },
            "reason": {
              "type": "string"
            },
            "next_action": {
              "type": "string",
              "enum": [
                "work",
                "verify",
                "accept",
                "status"
              ]
            }
          }
        }
      },
      "required": [
        "command",
        "data"
      ]
    }
  ]
}
