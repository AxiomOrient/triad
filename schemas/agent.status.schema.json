{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triad.local/schemas/agent.status.schema.json",
  "title": "Triad Agent Status Response",
  "type": "object",
  "allOf": [
    {
      "$ref": "./envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "command": {
          "const": "status",
          "type": "string"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "summary",
            "claims"
          ],
          "properties": {
            "summary": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "healthy",
                "needs_code",
                "needs_test",
                "needs_spec",
                "contradicted",
                "blocked"
              ],
              "properties": {
                "healthy": {
                  "type": "integer",
                  "minimum": 0
                },
                "needs_code": {
                  "type": "integer",
                  "minimum": 0
                },
                "needs_test": {
                  "type": "integer",
                  "minimum": 0
                },
                "needs_spec": {
                  "type": "integer",
                  "minimum": 0
                },
                "contradicted": {
                  "type": "integer",
                  "minimum": 0
                },
                "blocked": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            },
            "claims": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "claim_id",
                  "title",
                  "status",
                  "revision"
                ],
                "properties": {
                  "claim_id": {
                    "type": "string",
                    "pattern": "^REQ-[a-z0-9-]+\\-\\d{3}$"
                  },
                  "title": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "healthy",
                      "needs-code",
                      "needs-test",
                      "needs-spec",
                      "contradicted",
                      "blocked"
                    ]
                  },
                  "revision": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "pending_patch_id": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            }
          }
        }
      },
      "required": [
        "command",
        "data"
      ]
    }
  ]
}
