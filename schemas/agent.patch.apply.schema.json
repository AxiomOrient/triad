{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triad.local/schemas/agent.patch.apply.schema.json",
  "title": "Triad Agent Patch Apply Response",
  "type": "object",
  "allOf": [
    {
      "$ref": "./envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "command": {
          "const": "patch.apply",
          "type": "string"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "patch_id",
            "claim_id",
            "applied",
            "new_revision",
            "followup_action"
          ],
          "properties": {
            "patch_id": {
              "type": "string",
              "pattern": "^PATCH-\\d{6}$"
            },
            "claim_id": {
              "type": "string",
              "pattern": "^REQ-[a-z0-9-]+\\-\\d{3}$"
            },
            "applied": {
              "type": "boolean"
            },
            "new_revision": {
              "type": "integer",
              "minimum": 0
            },
            "followup_action": {
              "type": "string",
              "enum": [
                "verify",
                "status"
              ]
            }
          }
        }
      },
      "required": [
        "command",
        "data"
      ]
    }
  ]
}
