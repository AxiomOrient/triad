{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triad.local/schemas/agent.patch.propose.schema.json",
  "title": "Triad Agent Patch Propose Response",
  "type": "object",
  "allOf": [
    {
      "$ref": "./envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "command": {
          "const": "patch.propose",
          "type": "string"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "patch_id",
            "claim_id",
            "based_on_evidence",
            "path",
            "reason"
          ],
          "properties": {
            "patch_id": {
              "type": "string",
              "pattern": "^PATCH-\\d{6}$"
            },
            "claim_id": {
              "type": "string",
              "pattern": "^REQ-[a-z0-9-]+\\-\\d{3}$"
            },
            "based_on_evidence": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^EVID-\\d{6}$"
              }
            },
            "path": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            }
          }
        }
      },
      "required": [
        "command",
        "data"
      ]
    }
  ]
}
